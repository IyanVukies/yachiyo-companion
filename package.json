{
  "name": "yachiyo-companion",
  "version": "0.1.0",
  "description": "A calm Windows desktop companion for Hermes Agent",
  "main": "./out/main/index.js",
  "author": "Yachiyo Companion contributors",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build:live2d": "node scripts/build-live2d.mjs",
    "build:icons": "node scripts/build-icons.mjs",
    "dev": "npm run build:live2d && electron-vite dev",
    "start": "electron-vite preview",
    "build:app": "npm run build:live2d && electron-vite build",
    "build": "npm run typecheck && npm run build:app",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:sidecar": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-sidecar.ps1",
    "smoke:sidecar": "node scripts/smoke-sidecar.mjs",
    "test:e2e": "npm run build && playwright test",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run build:app",
    "verify:full": "npm run verify && npm run test:sidecar",
    "build:sidecar": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-sidecar.ps1",
    "package": "npm run build:icons && npm run verify:full && npm run build:sidecar && electron-builder --win nsis",
    "package:dir": "npm run build:icons && npm run verify:full && npm run build:sidecar && electron-builder --win dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "ffmpeg-static": "5.3.0",
    "ffprobe-static": "3.1.0",
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "yauzl": "3.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/yauzl": "3.4.0",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "esbuild": "^0.28.1",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "jsdom": "29.1.1",
    "png-to-ico": "^3.0.1",
    "prettier": "3.9.5",
    "sharp": "^0.34.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  },
  "build": {
    "appId": "com.yachiyo.companion",
    "productName": "Yachiyo Companion",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/sidecar/yachiyo-voice-sidecar",
        "to": "voice-sidecar"
      },
      {
        "from": "project-assets/README-PLACE-ASSETS-HERE.md",
        "to": "project-assets/README-PLACE-ASSETS-HERE.md"
      },
      {
        "from": "THIRD-PARTY-NOTICES.md",
        "to": "THIRD-PARTY-NOTICES.md"
      }
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/ffprobe-static/**"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "Yachiyo-Companion-${version}-${arch}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "Yachiyo Companion"
    },
    "publish": null
  }
}
